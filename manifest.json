{
  "manifest_version": 3,
  "name": "Better Roo",
  "version": "1.3.0",
  "description": "Better Deliveroo listings: FSA hygiene ratings, shared address badges, sortable cards, smart filters, and a compact table view.",

  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "*://deliveroo.co.uk/*",
    "https://api.ratings.food.gov.uk/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://deliveroo.co.uk/*"],
      "js": ["src/content/index.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Better Roo",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
